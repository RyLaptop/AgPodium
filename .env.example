# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# TAMU email allowlist (comma-separated domains)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=tamu.edu

# Resend (for transactional email — reminders) — get key at resend.com/api-keys
RESEND_API_KEY=
# Optional — until you verify yellpass.app in Resend, leave blank to use their
# shared sandbox sender (onboarding@resend.dev)
RESEND_FROM_EMAIL=

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron — random string, put the same value in your cron pinger's request.
# Protects /api/cron/* routes from being hit by randoms.
CRON_SECRET=
